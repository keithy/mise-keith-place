#!/bin/bash
#MISE description="Fix ownership and permissions for picoclaw repo"
set -euo pipefail

REPO_DIR="/code/picoclaw"

echo "Fixing ownership to infra:coder..."
sudo chown -R infra:coder "$REPO_DIR"

echo "Setting permissions..."
# Directories: 755
sudo find "$REPO_DIR" -type d -exec chmod 755 {} \;
# Files: 644, Executables: 755
sudo find "$REPO_DIR" -type f -exec chmod 644 {} \;
sudo find "$REPO_DIR" -type f -name '*.sh' -exec chmod 755 {} \;
sudo find "$REPO_DIR" -type f -path '*/.mise/tasks/*' -exec chmod 755 {} \;

echo "Done!"
